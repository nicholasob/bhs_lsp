{
	"compilerOptions": {
		"lib": ["es2020"],
		"target": "es2020",
		"module": "commonjs",
		"moduleResolution": "node",
		"ignoreDeprecations": "6.0",
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"sourceMap": true,
		"strict": true,
		"noUnusedLocals": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"outDir": "out",
		"rootDir": "src"
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
