{
  "name": "Big Huge Script",
  "scopeName": "source.bhs",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#struct-declarations" },
    { "include": "#script-declarations" },
    { "include": "#trigger-declarations" },
    { "include": "#labels" },
    { "include": "#casts" },
    { "include": "#storage-types" },
    { "include": "#custom-types" },
    { "include": "#storage-modifiers" },
    { "include": "#control-keywords" },
    { "include": "#other-keywords" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#member-access" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#unsupported-types" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.bhs",
          "match": "//.*$"
        },
        {
          "include": "#block-comment"
        }
      ]
    },
    "block-comment": {
      "name": "comment.block.bhs",
      "begin": "/\\*",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.comment.begin.bhs" }
      },
      "end": "\\*/",
      "endCaptures": {
        "0": { "name": "punctuation.definition.comment.end.bhs" }
      },
      "patterns": [
        { "include": "#block-comment" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bhs",
          "begin": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.bhs" }
          },
          "end": "\"",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.bhs" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.bhs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.single.bhs",
          "begin": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.bhs" }
          },
          "end": "'",
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.bhs" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.bhs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "script-declarations": {
      "patterns": [
        {
          "name": "meta.function.bhs",
          "match": "(?i)\\b(scenario|conquest|ai)\\s+([A-Za-z_]\\w*)\\b",
          "captures": {
            "1": { "name": "storage.type.function.bhs" },
            "2": { "name": "entity.name.function.bhs" }
          }
        },
        {
          "name": "storage.type.function.bhs",
          "match": "(?i)\\b(?:scenario|conquest|ai)\\b"
        }
      ]
    },
    "struct-declarations": {
      "patterns": [
        {
          "name": "meta.struct.bhs",
          "match": "\\b(struct)\\s+([A-Za-z_]\\w*)\\b",
          "captures": {
            "1": { "name": "keyword.declaration.struct.bhs" },
            "2": { "name": "entity.name.type.struct.bhs" }
          }
        }
      ]
    },
    "trigger-declarations": {
      "patterns": [
        {
          "name": "meta.function.trigger.bhs",
          "match": "\\b(trigger)\\s+([A-Za-z_]\\w*)\\b",
          "captures": {
            "1": { "name": "keyword.control.bhs" },
            "2": { "name": "entity.name.function.bhs" }
          }
        },
        {
          "name": "keyword.control.bhs",
          "match": "\\b(?:trigger|run_once)\\b"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "keyword.control.bhs",
          "match": "\\blabels\\b"
        },
        {
          "name": "constant.other.bhs",
          "match": "\\b[A-Z][A-Z0-9_]*\\b(?=\\s*(?:=|,|\\}))"
        }
      ]
    },
    "casts": {
      "patterns": [
        {
          "name": "meta.cast.bhs",
          "match": "(\\()\\s*([iI][nN][tT]|[fF][lL][oO][aA][tT]|[sS][tT][rR][iI][nN][gG]|[bB][oO][oO][lL])\\s*(\\[\\](?:\\s*\\[\\])*)?\\s*(\\))",
          "captures": {
            "1": { "name": "punctuation.section.parens.begin.bhs" },
            "2": { "name": "storage.type.bhs" },
            "3": { "name": "punctuation.definition.array.bhs" },
            "4": { "name": "punctuation.section.parens.end.bhs" }
          }
        }
      ]
    },
    "storage-types": {
      "patterns": [
        {
          "name": "storage.type.bhs",
          "match": "\\b(?:[iI][nN][tT]|[fF][lL][oO][aA][tT]|[sS][tT][rR][iI][nN][gG]|[bB][oO][oO][lL]|[vV][oO][iI][dD])\\b"
        }
      ]
    },
    "custom-types": {
      "patterns": [
        {
          "name": "meta.type.custom.array.bhs",
          "match": "(?i)\\b(?!(?:if|else|for|while|do|switch|case|default|break|continue|return|trigger|run_once|labels|include|static|local|ref|scenario|conquest|ai|true|false)\\b)(?!(?:int|float|real|string|bool|void|anytype|struct)\\b)([A-Za-z_]\\w*)(\\[\\](?:\\s*\\[\\])*)(?=\\s+(?:(?:scenario|conquest|ai)\\b|[A-Za-z_]\\w*(?:\\s*\\[\\])*\\s*(?:[=,;\\)])))",
          "captures": {
            "1": { "name": "entity.name.type.bhs" },
            "2": { "name": "punctuation.definition.array.bhs" }
          }
        },
        {
          "name": "entity.name.type.bhs",
          "match": "(?i)\\b(?!(?:if|else|for|while|do|switch|case|default|break|continue|return|trigger|run_once|labels|include|static|local|ref|scenario|conquest|ai|true|false)\\b)(?!(?:int|float|real|string|bool|void|anytype|struct)\\b)([A-Za-z_]\\w*)\\b(?=\\s+(?:(?:scenario|conquest|ai)\\b|[A-Za-z_]\\w*(?:\\s*\\[\\])*\\s*(?:[=,;\\)])))"
        }
      ]
    },
    "storage-modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.bhs",
          "match": "\\b(?:static|local|ref)\\b"
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.bhs",
          "match": "\\b(?:if|else|for|while|do|switch|case|default|break|continue|return)\\b"
        }
      ]
    },
    "other-keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.bhs",
          "match": "\\binclude\\b"
        },
        {
          "name": "support.function.bhs",
          "match": "\\$[A-Za-z_]\\w*(?=\\s*\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.bhs",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.bhs",
          "match": "(?<![\\w.])(?:(?:\\d+\\.\\d*|\\.\\d+)(?:[eE][+-]?\\d+)?|\\d+[eE][+-]?\\d+)"
        },
        {
          "name": "constant.numeric.integer.bhs",
          "match": "\\b(?:0[xX][0-9A-Fa-f]+|\\d+)\\b"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.bhs",
          "match": "\\b[A-Za-z_]\\w*\\b(?=\\s*\\()"
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "meta.member.access.bhs",
          "match": "(\\.)([A-Za-z_]\\w*)\\b",
          "captures": {
            "1": { "name": "punctuation.accessor.dot.bhs" },
            "2": { "name": "variable.other.member.bhs" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.bhs",
          "match": "<<=|>>=|\\+=|-=|\\*=|/=|%=|\\^=|="
        },
        {
          "name": "keyword.operator.bitwise.shift.bhs",
          "match": "<<|>>"
        },
        {
          "name": "keyword.operator.comparison.bhs",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.bhs",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.bhs",
          "match": "&|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.bhs",
          "match": "\\+\\+|--|\\+|-|\\*|/|%|\\^"
        },
        {
          "name": "keyword.operator.ternary.bhs",
          "match": "\\?|:"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.bhs",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.bhs",
          "match": ","
        },
        {
          "name": "punctuation.section.block.bhs",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.bhs",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.bhs",
          "match": "[\\[\\]]"
        }
      ]
    },
    "unsupported-types": {
      "patterns": [
        {
          "name": "invalid.illegal.bhs",
          "match": "\\b(?:[cC][hH][aA][rR]|[sS][hH][oO][rR][tT]|[dD][oO][uU][bB][lL][eE]|[lL][oO][nN][gG]|[uU][nN][sS][iI][gG][nN][eE][dD])\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.bhs",
          "match": "\\b[A-Za-z_]\\w*\\b"
        }
      ]
    }
  }
}
